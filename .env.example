# ─────────────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real values.
# ─────────────────────────────────────────────────────────────

# Supabase dev project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret. Used ONLY by service-role server routes
# (public QR submit endpoints, admin operations). NEVER exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# App config
NEXT_PUBLIC_APP_NAME=FleetWise
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Nightly cron secret. The /api/cron/nightly route requires
# `Authorization: Bearer ${CRON_SECRET}`. When set in the Vercel project, Vercel Cron
# sends this header automatically. Generate a long random value (e.g. `openssl rand -hex 32`).
# See docs/CRON.md.
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Web Push (F6) — self-hosted VAPID, no external provider.
# Generate a keypair with:  node scripts/gen-vapid-keys.mjs
# If these are UNSET, push simply no-ops (in-app alerts still work).
# ─────────────────────────────────────────────────────────────
# Server-only signing keys (never exposed to the browser).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI the push service can reach you at (mailto: or https:).
VAPID_SUBJECT=mailto:alerts@example.com
# Same value as VAPID_PUBLIC_KEY, exposed to the browser so it can subscribe.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─────────────────────────────────────────────────────────────
# Local RLS test database (used by supabase/tests/run.sh only —
# this is NOT the application database).
# ─────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql://postgres@localhost:5432/farmapp_test
